{% extends 'base.html.twig' %}

{% block title %}Modifier un chat{% endblock %}

{% block stylesheets %}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Lato:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Raleway:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
    <link
        rel="stylesheet"
        href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
        integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
        crossorigin=""
    >
    <link rel="stylesheet" href="/styles/frontignan-map.css?v=20260415-6">
{% endblock %}

{% block javascripts %}
    <script id="edit-chat-config" type="application/json">{{ {
        defaultLatitude: chat.latitude,
        defaultLongitude: chat.longitude,
        backUrl: path('app_home_mode', { mode: 'chat' }),
        updateUrl: path('api_lieux_chat_update', { id: chat.id }),
        chat: chat
    }|json_encode|raw }}</script>
    <script
        src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
        integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
        crossorigin=""
    ></script>
    <script src="/js/edit-chat-map.js?v=20260415-6" defer></script>
{% endblock %}

{% block body %}
    <section class="projets-page" data-edit-chat-app>
        <div class="map-card add-chat-card">
            <div class="add-chat-topbar">
                <a href="{{ path('app_home_mode', { mode: 'chat' }) }}" class="btn-secondary add-chat-back-link">Retour a la liste</a>
            </div>

            <p class="sur-titre">Modification</p>
            <h1>Modifier un chat</h1>
            <p class="description">
                Ajustez la position sur la carte si besoin, modifiez la fiche, puis enregistrez les changements.
            </p>

            <section class="mode-list add-chat-status-panel" aria-live="polite">
                <div class="mode-list-header">
                    <div class="mode-list-heading">
                        <h2 class="mode-list-title">Position du chat</h2>
                        <p class="mode-list-count" data-selected-coordinates>Aucun point selectionne</p>
                    </div>
                </div>
                <p class="mode-list-empty" data-edit-chat-help>Cliquez sur la carte pour repositionner le marqueur du chat.</p>
                <p class="mode-list-empty auto-address-status" data-geocode-status hidden></p>
            </section>

            <div id="edit-chat-map" class="leaflet-map" aria-label="Carte pour modifier un chat"></div>

            <p class="message-erreur standalone-error" data-error-message hidden></p>

            <section class="chat-form add-chat-form-panel" data-chat-form-section>
                <div class="form-header">
                    <div>
                        <h2>🐾 Fiche d identification chat</h2>
                        <p class="form-subtitle">Mettez a jour la fiche puis enregistrez.</p>
                    </div>
                    <div class="header-actions">
                        <button type="button" class="btn-primary" data-action="save-chat">
                            Enregistrer les modifications
                        </button>
                    </div>
                </div>

                <form class="form-grid" data-chat-form>
                    {% include 'home/_chat_form_fields.html.twig' %}
                </form>

                <div class="form-footer-actions">
                    <button type="button" class="btn-primary" data-action="save-chat">
                        Enregistrer les modifications
                    </button>
                </div>
            </section>

            <div class="toast-notification" data-success-toast hidden></div>
        </div>
    </section>
{% endblock %}
