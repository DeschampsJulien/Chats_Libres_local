<div class="form-section">
    <h3>Maison</h3>
    <label for="maisonNom">Nom *</label>
    <input id="maisonNom" name="nom" type="text" required>
    <label for="maisonAdresse">Adresse *</label>
    <input id="maisonAdresse" name="adresse" type="text" required>
    <label for="maisonCommentaire">Commentaire</label>
    <textarea id="maisonCommentaire" name="commentaire" rows="4"></textarea>
</div>

<div class="form-section">
    <h3>Position</h3>
    <label for="maisonLatitude">Latitude</label>
    <input id="maisonLatitude" name="latitude" type="text" readonly>
    <label for="maisonLongitude">Longitude</label>
    <input id="maisonLongitude" name="longitude" type="text" readonly>
</div>
